# Google Gemini Developer API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Google Cloud Vertex AI Configuration (Optional, set to True to enable)
USE_VERTEX=True
VERTEX_PROJECT=your_gcp_project_id_here
VERTEX_LOCATION=us-central1

# Rate Limiting & Performance settings
GEMINI_CONCURRENT_WORKERS=5
GEMINI_BATCH_SIZE=40
GEMINI_MIN_INTERVAL_S=3.5
GEMINI_JITTER_S=0.5
