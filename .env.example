# === Azure AD App Registration (Client Credentials Flow) ===
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# === SharePoint Configuration ===
# Source (Input CRM_merge.xlsx from CRM-CTDA site)
SHAREPOINT_SOURCE_DRIVE_ID=b!K2h3C6y-m0-nfhBTKpRGUHVm2ajJ6j5Liiy5S410oj50hc-yscOEQrZMgUgL5YIr
SHAREPOINT_SOURCE_FILE_PATH=CRM_merge/CRM_merge.xlsx

# Target (Output Phân loại dữ liệu công trình dự án CRM V4.xlsx to DataPBI_salein site)
SHAREPOINT_TARGET_DRIVE_ID=b!NtlOjnoIAUGK2TSeHPN7wre_0vBaUZhHrpr9lFi7hWvJ-n1mRHXzSr4E9Qjzat5Q
SHAREPOINT_TARGET_FILE_PATH=Data Lake to SharePoint/Phan_Tich_CRM/Phân loại dữ liệu công trình dự án CRM V4.xlsx

# === Email Notification Configuration ===
NOTIFICATION_SENDER_EMAIL=sender@yourdomain.com
NOTIFICATION_RECIPIENTS=recipient1@domain.com,recipient2@domain.com

# === Google Gemini & Vertex AI Backend ===
USE_VERTEX=True
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=us-central1
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash

# === Rate Limiting & Performance settings ===
GEMINI_CONCURRENT_WORKERS=3
GEMINI_BATCH_SIZE=40
GEMINI_MIN_INTERVAL_S=7.5
GEMINI_JITTER_S=1.5
